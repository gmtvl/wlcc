{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build Debug",
            "type": "shell",
            "command": "cl",
            "args": [
                "/std:c++20",
                "/EHsc",
                "/Zi",
                "/Od",
                "/I", "include",
                "src\\*.cpp",
                "/Fe:build\\app_debug.exe"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$msCompile"]
        },
        {
            "label": "Build Release",
            "type": "shell",
            "command": "cl",
            "args": [
                "/std:c++20",
                "/EHsc",
                "/O2",
                "/I", "include",
                "src\\*.cpp",
                "/Fe:build\\app_release.exe"
            ],
            "problemMatcher": ["$msCompile"]
        }
    ]
}