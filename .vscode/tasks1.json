{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build with MSVC",
            "type": "shell",
            "command": "cl",
            "args": [
                "/EHsc",
                "/Zi",
               "/I",
                "include",
                "src\\*.cpp",
                "/Fe:app.exe"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$msCompile"]
        }
    ]
}